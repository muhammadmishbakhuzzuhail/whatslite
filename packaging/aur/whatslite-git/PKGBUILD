# Maintainer: muhammadmishbakhuzzuhail <m.ilhamnadhif121@gmail.com>
# whatslite-git — builds the latest commit from source.
# Install:  yay -S whatslite-git   (or makepkg -si in this directory)

pkgname=whatslite-git
_pkgname=whatslite
pkgver=r1
pkgrel=1
pkgdesc="Lightweight desktop WhatsApp client for Linux (no Chromium; WebKitGTK + whatsmeow)"
arch=('x86_64')
url="https://github.com/muhammadmishbakhuzzuhail/whatslite"
license=('GPL-3.0-or-later')
depends=('webkit2gtk-4.1' 'gtk3')
makedepends=('go' 'nodejs' 'npm' 'git' 'pkgconf')
provides=('whatslite')
conflicts=('whatslite')
source=("${_pkgname}::git+https://github.com/muhammadmishbakhuzzuhail/whatslite.git")
sha256sums=('SKIP')

pkgver() {
	cd "${_pkgname}"
	printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
	cd "${_pkgname}"
	# Build the Wails CLI into a local GOBIN (no global install needed).
	export GOPATH="${srcdir}/gopath"
	export GOBIN="${srcdir}/gobin"
	export PATH="${GOBIN}:${PATH}"
	go install github.com/wailsapp/wails/v2/cmd/wails@latest
	# webkit2_41 → WebKitGTK 4.1; netgo → pure-Go DNS (avoids the WebKitGTK
	# CGo-resolver crash). Wails runs `npm install` + `npm run build` itself.
	# Stamp the build version (git describe form) into main.version.
	wails build -tags "webkit2_41 netgo" -clean -ldflags "-X main.version=${pkgver}"
}

package() {
	cd "${_pkgname}"
	install -Dm755 "build/bin/whatslite" "${pkgdir}/usr/bin/whatslite"
	install -Dm644 "build/linux/whatslite.desktop" "${pkgdir}/usr/share/applications/whatslite.desktop"
	install -Dm644 "build/linux/whatslite.svg" "${pkgdir}/usr/share/icons/hicolor/scalable/apps/whatslite.svg"
	install -Dm644 "LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
